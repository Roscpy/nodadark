{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "NodaDark",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "execute": false },
      "dialog": { "open": true, "save": true },
      "fs": { "scope": ["$APPDATA/nodadark/*", "$LOCALAPPDATA/nodadark/*"] },
      "notification": { "all": true },
      "clipboard": { "all": true }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.nodadark.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": "default-src 'self'; style-src 'unsafe-inline'"
    },
    "windows": [
      {
        "title": "NodaDark — Proxy d'Interception",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
